<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pageScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:descendantFocusability="beforeDescendants"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/menuButton"
                    android:layout_width="58dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_outline_button"
                    android:text="Menu"
                    android:textAllCaps="false"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="UAC Spoofer"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/themeButton"
                    android:layout_width="70dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_outline_button"
                    android:text="Light"
                    android:textAllCaps="false"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/statusSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_status_idle"
                android:gravity="center"
                android:text="Ready"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/activeConfigText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Active config"
                android:textColor="@color/ink"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/targetText"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:text="No config selected"
                android:textColor="@color/ink"
                android:textDirection="ltr"
                android:textSize="13sp"
                android:typeface="monospace" />

            <TextView
                android:id="@+id/connectedPingText"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:text="Connected ping: --"
                android:textColor="@color/muted"
                android:textDirection="ltr"
                android:textSize="12sp"
                android:typeface="monospace" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/runButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_run"
                    android:text="@string/run"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/stopButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stop"
                    android:text="@string/stop"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/trafficText"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:text="0 B / 0 B"
                android:textColor="@color/muted"
                android:textDirection="ltr"
                android:textSize="12sp"
                android:typeface="monospace" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/configsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configs"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/addConfigButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_outline_button"
                    android:text="Add"
                    android:textAllCaps="false"
                    android:textColor="@color/ink" />

                <Button
                    android:id="@+id/editConfigButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_outline_button"
                    android:text="Edit"
                    android:textAllCaps="false"
                    android:textColor="@color/ink" />

                <Button
                    android:id="@+id/importClipboardButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1.35"
                    android:background="@drawable/bg_outline_button"
                    android:text="Clipboard"
                    android:textAllCaps="false"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/configsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/scannerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanner"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/startScanButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_run"
                    android:text="Scan"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/stopScanButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stop"
                    android:text="Stop"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/scannerStatusText"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_chip"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Scanner idle"
                android:textColor="@color/muted"
                android:textSize="12sp" />

            <com.uac.spoofer.InnerScrollView
                android:id="@+id/scannerResultsScroll"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:clickable="true"
                android:descendantFocusability="blocksDescendants"
                android:fillViewport="false"
                android:focusable="false"
                android:nestedScrollingEnabled="true"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/resultsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </com.uac.spoofer.InnerScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/logsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Live Logs"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_log"
                android:descendantFocusability="blocksDescendants"
                android:fillViewport="true"
                android:focusable="false"
                android:padding="12dp">

                <TextView
                    android:id="@+id/logText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:textColor="#D7E3EA"
                    android:textDirection="ltr"
                    android:textIsSelectable="false"
                    android:textSize="12sp"
                android:typeface="monospace" />
            </ScrollView>
        </LinearLayout>

        <TextView
            android:id="@+id/creditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:minHeight="58dp"
            android:padding="10dp"
            android:text="credits to behroozuac&#10;Support: @Beh50roocentzuac"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>

